# =============================================================================
# SNISID — Configuration Globale
# Système National d'Identification Sécurisée et d'Interopérabilité Digitale
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs

# --- Application ---
APP_ENV=development
APP_NAME=snisid-platform
APP_VERSION=1.0.0
LOG_LEVEL=debug

# --- Serveur HTTP ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_TIMEOUT=30s

# --- Base de données PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=snisid
DB_USER=snisid
DB_PASSWORD=changer_moi
DB_SSLMODE=disable
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- CockroachDB (Event Sourcing) ---
COCKROACH_HOST=localhost
COCKROACH_PORT=26257
COCKROACH_DB=snisid_ledger
COCKROACH_USER=snisid
COCKROACH_PASSWORD=changer_moi

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Neo4j ---
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changer_moi

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=snisid-platform
KAFKA_CONSUMER_GROUP=snisid-core

# --- Milvus (Biométrie vectorielle) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- ClickHouse (Analytics) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=snisid
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changer_moi

# --- JWT ---
JWT_SECRET=your-jwt-secret
JWT_TTL=15m
JWT_REFRESH_TTL=24h

# --- HSM / PKI ---
HSM_PIN=changer_moi
HSM_SLOT_ID=0
HSM_PKCS11_LIB=/usr/lib/softhsm/libsofthsm2.so
TRUST_DOMAIN=snisid.gouv.ht

# --- SPIRE / SPIFFE ---
SPIRE_AGENT_SOCKET=/tmp/spire-agent/public/api.sock
SPIRE_TRUST_DOMAIN=snisid.gouv.ht

# --- Vault ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=changer_moi
VAULT_KV_PATH=secret/snisid

# --- Observabilité ---
OTEL_SERVICE_NAME=snisid-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_ADDR=0.0.0.0:2112

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
VITE_OIDC_AUTHORITY=http://localhost:8080/realms/snisid
VITE_OIDC_CLIENT_ID=snisid-frontend

# --- AI / ML ---
AI_MODEL_ENDPOINT=http://localhost:8501
AI_INFERENCE_TIMEOUT=5s
FRAUD_MODEL_PATH=/models/fraud/v1

# --- Feature Flags ---
FF_ENABLE_DEEPFAKE_DETECTION=false
FF_ENABLE_FEDERATED_SEARCH=false
FF_ENABLE_OFFLINE_MODE=true

# --- Sécurité ---
ENCRYPTION_KEY=changer_moi_32_bytes_xxxxxx
RATE_LIMIT_REQ_PER_SEC=100
CORS_ORIGINS=http://localhost:5173
