{
  "title": "SNISID Identity Service Monitoring",
  "uid": "snisid-identity",
  "panels": [
    {"title": "Request Rate", "type": "timeseries", "targets": [{"expr": "rate(http_requests_total{service=\"identity\"}[5m])"}]},
    {"title": "Error Rate", "type": "timeseries", "targets": [{"expr": "rate(http_requests_total{service=\"identity\", status=~\"5..\"}[5m])"}]},
    {"title": "P99 Latency", "type": "timeseries", "targets": [{"expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{service=\"identity\"}[5m]))"}]},
    {"title": "Active Users", "type": "stat", "targets": [{"expr": "sum(active_sessions{service=\"identity\"})"}]}
  ]
}
