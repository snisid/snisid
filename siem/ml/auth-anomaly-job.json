{
  "job_id": "snisid_auth_rare_geography",
  "description": "Detects unusual login locations for SNISID operators based on historical baselines.",
  "analysis_config": {
    "bucket_span": "15m",
    "detectors": [
      {
        "detector_description": "Rare login location for user",
        "function": "rare",
        "by_field_name": "source.geo.city_name",
        "partition_field_name": "user.name"
      }
    ],
    "influencers": [
      "user.name",
      "source.ip",
      "source.geo.country_iso_code"
    ]
  },
  "data_description": {
    "time_field": "@timestamp"
  },
  "custom_settings": {
    "created_by": "snisid_soc_architect"
  }
}
