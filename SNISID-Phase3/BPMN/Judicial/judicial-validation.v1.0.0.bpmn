<?xml version="1.0" encoding="UTF-8"?>
<!-- judicial.validation.act v1.0.0 — Validation juridique d'actes administratifs (admissibilité légale) -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_jud_val" targetNamespace="https://snisid.gouv.ht/bpmn/judicial">
  <bpmn:process id="judicial.validation.act" name="Validation judiciaire d'acte" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Hash" name="Hash + chaîne preuve (chain of custody)"><bpmn:extensionElements><zeebe:taskDefinition type="evidence.chain.create"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="Clerk" name="Greffier - réception"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="court-clerks"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Judge" name="Magistrat - validation"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="civil-judges"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Sign" name="Signature qualifiée (eIDAS-like)"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="TSA" name="Horodatage RFC 3161"><bpmn:extensionElements><zeebe:taskDefinition type="tsa.timestamp"/></bpmn:extensionElements><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="WORM" name="Archivage WORM (légal)"><bpmn:extensionElements><zeebe:taskDefinition type="storage.worm.write"/></bpmn:extensionElements><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K" name="Kafka judicial.validated"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f9</bpmn:incoming></bpmn:endEvent>

    <bpmn:boundaryEvent id="Sla" attachedToRef="Judge" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT48H</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="Esc"><bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements><bpmn:incoming>fE</bpmn:incoming><bpmn:outgoing>fE2</bpmn:outgoing></bpmn:callActivity>
    <bpmn:endEvent id="EE"><bpmn:incoming>fE2</bpmn:incoming></bpmn:endEvent>

    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="Hash"/>
    <bpmn:sequenceFlow id="f3" sourceRef="Hash" targetRef="Clerk"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Clerk" targetRef="Judge"/>
    <bpmn:sequenceFlow id="f5" sourceRef="Judge" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Sign" targetRef="TSA"/>
    <bpmn:sequenceFlow id="f7" sourceRef="TSA" targetRef="WORM"/>
    <bpmn:sequenceFlow id="f8" sourceRef="WORM" targetRef="K"/>
    <bpmn:sequenceFlow id="f9" sourceRef="K" targetRef="E"/>
    <bpmn:sequenceFlow id="fE" sourceRef="Sla" targetRef="Esc"/>
    <bpmn:sequenceFlow id="fE2" sourceRef="Esc" targetRef="EE"/>
  </bpmn:process>
</bpmn:definitions>
