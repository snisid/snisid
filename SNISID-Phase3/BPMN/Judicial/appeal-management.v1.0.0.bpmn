<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_jud_app" targetNamespace="https://snisid.gouv.ht/bpmn/judicial">
  <bpmn:process id="judicial.appeal.management" name="Gestion appel judiciaire" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="Filing" name="Dépôt requête appel"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="court-clerks"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Notify1" name="Notification parties"><bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="Hearing" name="Audience cour d'appel"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="appeal-judges"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Ruling" name="Arrêt cour d'appel"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="appeal-judges"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Sign"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f8</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="Filing"/>
    <bpmn:sequenceFlow id="f3" sourceRef="Filing" targetRef="Notify1"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Notify1" targetRef="Hearing"/>
    <bpmn:sequenceFlow id="f5" sourceRef="Hearing" targetRef="Ruling"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Ruling" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f7" sourceRef="Sign" targetRef="K"/>
    <bpmn:sequenceFlow id="f8" sourceRef="K" targetRef="E"/>
  </bpmn:process>
</bpmn:definitions>
