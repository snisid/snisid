<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_id_rev" targetNamespace="https://snisid.gouv.ht/bpmn/identity">
  <bpmn:process id="identity.revocation.administrative" name="Révocation identité" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="Reason" name="Saisie motif révocation"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="oni-agents-l2"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Legal" name="Validation juridique"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="legal-officers"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Sup" name="Validation superviseur"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="oni-supervisors"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Revoke" name="Révocation NIN + carte + credentials"><bpmn:extensionElements><zeebe:taskDefinition type="identity.revoke"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="CRL" name="Mise à jour CRL/OCSP PKI"><bpmn:extensionElements><zeebe:taskDefinition type="pki.crl.publish"/></bpmn:extensionElements><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Sign"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K" name="Kafka identity.revoked"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f9</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="Reason"/>
    <bpmn:sequenceFlow id="f3" sourceRef="Reason" targetRef="Legal"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Legal" targetRef="Sup"/>
    <bpmn:sequenceFlow id="f5" sourceRef="Sup" targetRef="Revoke"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Revoke" targetRef="CRL"/>
    <bpmn:sequenceFlow id="f7" sourceRef="CRL" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f8" sourceRef="Sign" targetRef="K"/>
    <bpmn:sequenceFlow id="f9" sourceRef="K" targetRef="E"/>
      <bpmn:boundaryEvent id="SlaBE" attachedToRef="Sup" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fSlaE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="SlaEsc"><bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements>
      <bpmn:incoming>fSlaE</bpmn:incoming><bpmn:outgoing>fSlaE2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="SlaEnd"><bpmn:incoming>fSlaE2</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="fSlaE" sourceRef="SlaBE" targetRef="SlaEsc"/>
    <bpmn:sequenceFlow id="fSlaE2" sourceRef="SlaEsc" targetRef="SlaEnd"/>
    <bpmn:serviceTask id="Notify" name="Notification citoyen"><bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements></bpmn:serviceTask>
</bpmn:process>
</bpmn:definitions>
