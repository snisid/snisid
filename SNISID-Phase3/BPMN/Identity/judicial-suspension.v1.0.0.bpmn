<?xml version="1.0" encoding="UTF-8"?>
<!-- identity.suspension.judicial v1.0.0 — Façade Identity qui invoque le workflow judicial.suspension.identity -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_id_susp" targetNamespace="https://snisid.gouv.ht/bpmn/identity">
  <bpmn:process id="identity.suspension.judicial" name="Suspension judiciaire identité (façade)" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A" name="Audit start"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:callActivity id="Call" name="Délégation au workflow judiciaire">
      <bpmn:extensionElements><zeebe:calledElement processId="judicial.suspension.identity"/></bpmn:extensionElements>
      <bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:serviceTask id="Sign" name="Signature PKI acte"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K" name="Kafka identity.suspended.v1"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="N" name="Notification citoyen"><bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f6</bpmn:incoming></bpmn:endEvent>
    <bpmn:boundaryEvent id="Sla24h" attachedToRef="Call" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="Esc"><bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements><bpmn:incoming>fE</bpmn:incoming><bpmn:outgoing>fE2</bpmn:outgoing></bpmn:callActivity>
    <bpmn:endEvent id="EE"><bpmn:incoming>fE2</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="Call"/>
    <bpmn:sequenceFlow id="f3" sourceRef="Call" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Sign" targetRef="K"/>
    <bpmn:sequenceFlow id="f5" sourceRef="K" targetRef="N"/>
    <bpmn:sequenceFlow id="f6" sourceRef="N" targetRef="E"/>
    <bpmn:sequenceFlow id="fE" sourceRef="Sla24h" targetRef="Esc"/>
    <bpmn:sequenceFlow id="fE2" sourceRef="Esc" targetRef="EE"/>
  </bpmn:process>
</bpmn:definitions>
