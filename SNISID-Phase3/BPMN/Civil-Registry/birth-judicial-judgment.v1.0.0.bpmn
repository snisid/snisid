<?xml version="1.0" encoding="UTF-8"?>
<!-- civil-registry.birth.judicial-judgment v1.0.0 — Naissance par jugement (minutes judiciaires) -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Def_birth_judg" targetNamespace="https://snisid.gouv.ht/bpmn/civil-registry">
  <bpmn:process id="civil-registry.birth.judicial-judgment"
                name="Naissance — Jugement (minutes judiciaires)"
                isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="Start"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A" name="Audit">
      <bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements>
      <bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="FetchMinutes" name="Récupération minutes tribunal">
      <bpmn:extensionElements><zeebe:taskDefinition type="judicial.minutes.fetch"/></bpmn:extensionElements>
      <bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="ClerkVerify" name="Vérification greffier">
      <bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="court-clerks"/></bpmn:extensionElements>
      <bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="OniValidate" name="Transcription état civil ONI">
      <bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="oni-supervisors"/></bpmn:extensionElements>
      <bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Sign" name="Signature PKI">
      <bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements>
      <bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="Enroll">
      <bpmn:extensionElements><zeebe:calledElement processId="identity.enrollment.standard"/></bpmn:extensionElements>
      <bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:serviceTask id="Emit" name="Kafka birth.from-judgment">
      <bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements>
      <bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End"><bpmn:incoming>f8</bpmn:incoming></bpmn:endEvent>

    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="FetchMinutes"/>
    <bpmn:sequenceFlow id="f3" sourceRef="FetchMinutes" targetRef="ClerkVerify"/>
    <bpmn:sequenceFlow id="f4" sourceRef="ClerkVerify" targetRef="OniValidate"/>
    <bpmn:sequenceFlow id="f5" sourceRef="OniValidate" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Sign" targetRef="Enroll"/>
    <bpmn:sequenceFlow id="f7" sourceRef="Enroll" targetRef="Emit"/>
    <bpmn:sequenceFlow id="f8" sourceRef="Emit" targetRef="End"/>
      <bpmn:boundaryEvent id="SlaBE" attachedToRef="OniValidate" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P60D</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fSlaE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="SlaEsc"><bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements>
      <bpmn:incoming>fSlaE</bpmn:incoming><bpmn:outgoing>fSlaE2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="SlaEnd"><bpmn:incoming>fSlaE2</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="fSlaE" sourceRef="SlaBE" targetRef="SlaEsc"/>
    <bpmn:sequenceFlow id="fSlaE2" sourceRef="SlaEsc" targetRef="SlaEnd"/>
    <bpmn:serviceTask id="Notify" name="Notification citoyen"><bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements></bpmn:serviceTask>
</bpmn:process>
</bpmn:definitions>
