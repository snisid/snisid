<?xml version="1.0" encoding="UTF-8"?>
<!--
  SNISID - Civil Registry / Birth - Reconnaissance juridique
  Workflow ID : civil-registry.birth.recognition
  Version     : 1.0.0
  SLA         : 72h
-->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_civil_birth_recognition_v1"
                  targetNamespace="https://snisid.gouv.ht/bpmn/civil-registry">
  <bpmn:process id="civil-registry.birth.recognition"
                name="Naissance — Reconnaissance juridique"
                isExecutable="true" zeebe:versionTag="1.0.0">

    <bpmn:startEvent id="Start" name="Demande de reconnaissance">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="AuditStart" name="Audit start">
      <bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements>
      <bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="LegalReview" name="Revue juridique (Tribunal/Notaire)">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition candidateGroups="judicial-officers"/>
      </bpmn:extensionElements>
      <bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwLegal" name="Acte juridique valide ?">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>fOk</bpmn:outgoing><bpmn:outgoing>fKo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:callActivity id="CallFraud" name="Détection fraude">
      <bpmn:extensionElements><zeebe:calledElement processId="fraud.detection.automated"/></bpmn:extensionElements>
      <bpmn:incoming>fOk</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:userTask id="SupervisorOk" name="Double validation ONI">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition candidateGroups="oni-supervisors"/>
      </bpmn:extensionElements>
      <bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Sign" name="Signature PKI">
      <bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements>
      <bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Emit" name="Émission birth.recognized">
      <bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements>
      <bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Notify" name="Notification">
      <bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements>
      <bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndOk" name="Reconnaissance enregistrée"><bpmn:incoming>f8</bpmn:incoming></bpmn:endEvent>
    <bpmn:endEvent id="EndKo" name="Rejet juridique"><bpmn:incoming>fKo</bpmn:incoming></bpmn:endEvent>

    <bpmn:boundaryEvent id="Sla72h" name="SLA 72h" attachedToRef="LegalReview" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT72H</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fEsc</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="Esc" name="Escalation SLA">
      <bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements>
      <bpmn:incoming>fEsc</bpmn:incoming><bpmn:outgoing>fEsc2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="EndEsc"><bpmn:incoming>fEsc2</bpmn:incoming></bpmn:endEvent>

    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="AuditStart"/>
    <bpmn:sequenceFlow id="f2" sourceRef="AuditStart" targetRef="LegalReview"/>
    <bpmn:sequenceFlow id="f3" sourceRef="LegalReview" targetRef="GwLegal"/>
    <bpmn:sequenceFlow id="fOk" sourceRef="GwLegal" targetRef="CallFraud">
      <bpmn:conditionExpression>= legalValid = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="fKo" sourceRef="GwLegal" targetRef="EndKo">
      <bpmn:conditionExpression>= legalValid = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f4" sourceRef="CallFraud" targetRef="SupervisorOk"/>
    <bpmn:sequenceFlow id="f5" sourceRef="SupervisorOk" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Sign" targetRef="Emit"/>
    <bpmn:sequenceFlow id="f7" sourceRef="Emit" targetRef="Notify"/>
    <bpmn:sequenceFlow id="f8" sourceRef="Notify" targetRef="EndOk"/>
    <bpmn:sequenceFlow id="fEsc" sourceRef="Sla72h" targetRef="Esc"/>
    <bpmn:sequenceFlow id="fEsc2" sourceRef="Esc" targetRef="EndEsc"/>
  </bpmn:process>
</bpmn:definitions>
