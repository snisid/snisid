<?xml version="1.0" encoding="UTF-8"?>
<!-- civil-registry.disappearance.administrative v1.0.0 — SLA 1 an — Disparition administrative -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Def_disap" targetNamespace="https://snisid.gouv.ht/bpmn/civil-registry">
  <bpmn:process id="civil-registry.disappearance.administrative" name="Disparition administrative"
                isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A" name="Audit"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="PoliceReport" name="Rapport police"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="police-officers"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Wait" name="Délai légal (1 an)"><bpmn:extensionElements><zeebe:taskDefinition type="timer.legal-wait"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="Court" name="Jugement déclaratif disparition"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="civil-judges"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Sign" name="PKI sign"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Susp" name="Suspension identité"><bpmn:extensionElements><zeebe:taskDefinition type="identity.suspend"/></bpmn:extensionElements><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K" name="Kafka civil.disappearance"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f8</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="PoliceReport"/>
    <bpmn:sequenceFlow id="f3" sourceRef="PoliceReport" targetRef="Wait"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Wait" targetRef="Court"/>
    <bpmn:sequenceFlow id="f5" sourceRef="Court" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Sign" targetRef="Susp"/>
    <bpmn:sequenceFlow id="f7" sourceRef="Susp" targetRef="K"/>
    <bpmn:sequenceFlow id="f8" sourceRef="K" targetRef="E"/>
      <bpmn:boundaryEvent id="SlaBE" attachedToRef="Court" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P365D</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fSlaE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="SlaEsc"><bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements>
      <bpmn:incoming>fSlaE</bpmn:incoming><bpmn:outgoing>fSlaE2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="SlaEnd"><bpmn:incoming>fSlaE2</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="fSlaE" sourceRef="SlaBE" targetRef="SlaEsc"/>
    <bpmn:sequenceFlow id="fSlaE2" sourceRef="SlaEsc" targetRef="SlaEnd"/>
    <bpmn:serviceTask id="Notify" name="Notification citoyen"><bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements></bpmn:serviceTask>
</bpmn:process>
</bpmn:definitions>
