<?xml version="1.0" encoding="UTF-8"?>
<!-- civil-registry.death.standard v1.0.0 — SLA 24h -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Def_death_std" targetNamespace="https://snisid.gouv.ht/bpmn/civil-registry">
  <bpmn:process id="civil-registry.death.standard" name="Décès — Standard"
                isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="Start" name="Déclaration décès"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A1" name="Audit start">
      <bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements>
      <bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="MedCert" name="Certificat médical vérifié">
      <bpmn:extensionElements><zeebe:taskDefinition type="health.deathcert.verify"/></bpmn:extensionElements>
      <bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="Fraud">
      <bpmn:extensionElements><zeebe:calledElement processId="fraud.detection.automated"/></bpmn:extensionElements>
      <bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:userTask id="AgentVal" name="Validation agent ONI">
      <bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="oni-agents-l1"/></bpmn:extensionElements>
      <bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="SupVal" name="Validation superviseur (4-eyes)">
      <bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="oni-supervisors"/></bpmn:extensionElements>
      <bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Sign" name="Signature PKI acte de décès">
      <bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements>
      <bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Revoke" name="Révocation identité (déclencheur)">
      <bpmn:extensionElements><zeebe:taskDefinition type="identity.revoke.on-death"/></bpmn:extensionElements>
      <bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Emit" name="Kafka civil.death.registered">
      <bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements>
      <bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Notify" name="Notification famille + admin">
      <bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements>
      <bpmn:incoming>f9</bpmn:incoming><bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End"><bpmn:incoming>f10</bpmn:incoming></bpmn:endEvent>

    <bpmn:boundaryEvent id="Sla" attachedToRef="AgentVal" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="Esc">
      <bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements>
      <bpmn:incoming>fE</bpmn:incoming><bpmn:outgoing>fE2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="EndEsc"><bpmn:incoming>fE2</bpmn:incoming></bpmn:endEvent>

    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="A1"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A1" targetRef="MedCert"/>
    <bpmn:sequenceFlow id="f3" sourceRef="MedCert" targetRef="Fraud"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Fraud" targetRef="AgentVal"/>
    <bpmn:sequenceFlow id="f5" sourceRef="AgentVal" targetRef="SupVal"/>
    <bpmn:sequenceFlow id="f6" sourceRef="SupVal" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f7" sourceRef="Sign" targetRef="Revoke"/>
    <bpmn:sequenceFlow id="f8" sourceRef="Revoke" targetRef="Emit"/>
    <bpmn:sequenceFlow id="f9" sourceRef="Emit" targetRef="Notify"/>
    <bpmn:sequenceFlow id="f10" sourceRef="Notify" targetRef="End"/>
    <bpmn:sequenceFlow id="fE" sourceRef="Sla" targetRef="Esc"/>
    <bpmn:sequenceFlow id="fE2" sourceRef="Esc" targetRef="EndEsc"/>
  </bpmn:process>
</bpmn:definitions>
