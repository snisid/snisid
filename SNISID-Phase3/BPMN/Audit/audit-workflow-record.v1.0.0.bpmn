<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_aud_rec" targetNamespace="https://snisid.gouv.ht/bpmn/audit">
  <bpmn:process id="audit.workflow.record" name="Enregistrement audit (chain immuable)" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="Hash" name="Hash SHA-384 événement"><bpmn:extensionElements><zeebe:taskDefinition type="crypto.hash"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Chain" name="Chaînage hash précédent (Merkle)"><bpmn:extensionElements><zeebe:taskDefinition type="merkle.chain"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Sign"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="TSA"><bpmn:extensionElements><zeebe:taskDefinition type="tsa.timestamp"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="WORM" name="Écriture WORM"><bpmn:extensionElements><zeebe:taskDefinition type="storage.worm.write"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K" name="Kafka audit.*"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f7</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="Hash"/>
    <bpmn:sequenceFlow id="f2" sourceRef="Hash" targetRef="Chain"/>
    <bpmn:sequenceFlow id="f3" sourceRef="Chain" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Sign" targetRef="TSA"/>
    <bpmn:sequenceFlow id="f5" sourceRef="TSA" targetRef="WORM"/>
    <bpmn:sequenceFlow id="f6" sourceRef="WORM" targetRef="K"/>
    <bpmn:sequenceFlow id="f7" sourceRef="K" targetRef="E"/>
  </bpmn:process>
</bpmn:definitions>
