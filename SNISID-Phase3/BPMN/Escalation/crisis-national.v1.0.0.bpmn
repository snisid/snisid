<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_esc_crisis" targetNamespace="https://snisid.gouv.ht/bpmn/escalation">
  <bpmn:process id="escalation.crisis.national" name="Crise nationale (séisme, ouragan, cyber)" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Activate" name="Activation plan crise national"><bpmn:extensionElements><zeebe:taskDefinition type="crisis.plan.activate"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Notify" name="Notification gouvernement (CIMO)"><bpmn:extensionElements><zeebe:taskDefinition type="crisis.cimo.notify"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Failover" name="Bascule DR (DC3 Les Cayes)"><bpmn:extensionElements><zeebe:taskDefinition type="dr.failover"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Offline" name="Activation mode offline-first national"><bpmn:extensionElements><zeebe:taskDefinition type="offline.mode.enable"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f7</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="Activate"/>
    <bpmn:sequenceFlow id="f3" sourceRef="Activate" targetRef="Notify"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Notify" targetRef="Failover"/>
    <bpmn:sequenceFlow id="f5" sourceRef="Failover" targetRef="Offline"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Offline" targetRef="K"/>
    <bpmn:sequenceFlow id="f7" sourceRef="K" targetRef="E"/>
  </bpmn:process>
</bpmn:definitions>
