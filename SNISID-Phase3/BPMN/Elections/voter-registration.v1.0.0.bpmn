<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_elec_reg" targetNamespace="https://snisid.gouv.ht/bpmn/elections">
  <bpmn:process id="elections.voter.registration" name="Inscription électeur" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="VerifId" name="Vérification identité (NIN actif + non suspendu)"><bpmn:extensionElements><zeebe:taskDefinition type="identity.lookup"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="CheckAge" name="Vérification âge légal (18+)"><bpmn:extensionElements><zeebe:taskDefinition type="elections.eligibility.check"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="CheckJud" name="Vérification absence ban électoral"><bpmn:extensionElements><zeebe:taskDefinition type="judicial.flag.check"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:callActivity id="Fraud"><bpmn:extensionElements><zeebe:calledElement processId="fraud.detection.automated"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:callActivity>
    <bpmn:userTask id="CEP" name="Validation CEP (Conseil Électoral)"><bpmn:extensionElements><zeebe:assignmentDefinition candidateGroups="cep-officers"/></bpmn:extensionElements><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Bureau" name="Affectation bureau de vote"><bpmn:extensionElements><zeebe:taskDefinition type="elections.bureau.assign"/></bpmn:extensionElements><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Sign"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K" name="Kafka elections.voter.registered.v1"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f9</bpmn:incoming><bpmn:outgoing>f10</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="N"><bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements><bpmn:incoming>f10</bpmn:incoming><bpmn:outgoing>f11</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="E"><bpmn:incoming>f11</bpmn:incoming></bpmn:endEvent>
    <bpmn:boundaryEvent id="Sla" attachedToRef="CEP" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P7D</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="Esc"><bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements><bpmn:incoming>fE</bpmn:incoming><bpmn:outgoing>fE2</bpmn:outgoing></bpmn:callActivity>
    <bpmn:endEvent id="EE"><bpmn:incoming>fE2</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="VerifId"/>
    <bpmn:sequenceFlow id="f3" sourceRef="VerifId" targetRef="CheckAge"/>
    <bpmn:sequenceFlow id="f4" sourceRef="CheckAge" targetRef="CheckJud"/>
    <bpmn:sequenceFlow id="f5" sourceRef="CheckJud" targetRef="Fraud"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Fraud" targetRef="CEP"/>
    <bpmn:sequenceFlow id="f7" sourceRef="CEP" targetRef="Bureau"/>
    <bpmn:sequenceFlow id="f8" sourceRef="Bureau" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f9" sourceRef="Sign" targetRef="K"/>
    <bpmn:sequenceFlow id="f10" sourceRef="K" targetRef="N"/>
    <bpmn:sequenceFlow id="f11" sourceRef="N" targetRef="E"/>
    <bpmn:sequenceFlow id="fE" sourceRef="Sla" targetRef="Esc"/>
    <bpmn:sequenceFlow id="fE2" sourceRef="Esc" targetRef="EE"/>
  </bpmn:process>
</bpmn:definitions>
