<?xml version="1.0" encoding="UTF-8"?>
<!-- elections.voter.validation v1.0.0 — Validation jour J au bureau de vote (SLA 1h, p95<5min) -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Def_elec_val" targetNamespace="https://snisid.gouv.ht/bpmn/elections">
  <bpmn:process id="elections.voter.validation" name="Validation électeur (jour J)" isExecutable="true" zeebe:versionTag="1.0.0">
    <bpmn:startEvent id="S"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="A"><bpmn:extensionElements><zeebe:taskDefinition type="audit.emit"/></bpmn:extensionElements><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="VerifCard" name="Lecture carte e-ID + match biométrique 1:1"><bpmn:extensionElements><zeebe:taskDefinition type="biometric.match.1to1"/></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="CheckList" name="Vérification liste électorale + bureau"><bpmn:extensionElements><zeebe:taskDefinition type="elections.list.check"/></bpmn:extensionElements><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="CheckDup" name="Anti-double-vote (livenes ink + biometric)"><bpmn:extensionElements><zeebe:taskDefinition type="elections.antidup.check"/></bpmn:extensionElements><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:callActivity id="Fraud"><bpmn:extensionElements><zeebe:calledElement processId="fraud.detection.automated"/></bpmn:extensionElements><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:callActivity>
    <bpmn:exclusiveGateway id="Gw"><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>fOk</bpmn:outgoing><bpmn:outgoing>fKo</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Mark" name="Marquage électeur (encre + DB)"><bpmn:extensionElements><zeebe:taskDefinition type="elections.voter.mark"/></bpmn:extensionElements><bpmn:incoming>fOk</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Sign"><bpmn:extensionElements><zeebe:taskDefinition type="pki.sign.qualified"/></bpmn:extensionElements><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="K"><bpmn:extensionElements><zeebe:taskDefinition type="kafka.emit"/></bpmn:extensionElements><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="EOk"><bpmn:incoming>f9</bpmn:incoming></bpmn:endEvent>
    <bpmn:endEvent id="EKo" name="Vote refusé (fraude)"><bpmn:incoming>fKo</bpmn:incoming><bpmn:terminateEventDefinition/></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="A"/>
    <bpmn:sequenceFlow id="f2" sourceRef="A" targetRef="VerifCard"/>
    <bpmn:sequenceFlow id="f3" sourceRef="VerifCard" targetRef="CheckList"/>
    <bpmn:sequenceFlow id="f4" sourceRef="CheckList" targetRef="CheckDup"/>
    <bpmn:sequenceFlow id="f5" sourceRef="CheckDup" targetRef="Fraud"/>
    <bpmn:sequenceFlow id="f6" sourceRef="Fraud" targetRef="Gw"/>
    <bpmn:sequenceFlow id="fOk" sourceRef="Gw" targetRef="Mark"><bpmn:conditionExpression>= fraudScore &lt; 0.7</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="fKo" sourceRef="Gw" targetRef="EKo"><bpmn:conditionExpression>= fraudScore &gt;= 0.7</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f7" sourceRef="Mark" targetRef="Sign"/>
    <bpmn:sequenceFlow id="f8" sourceRef="Sign" targetRef="K"/>
    <bpmn:sequenceFlow id="f9" sourceRef="K" targetRef="EOk"/>
      <bpmn:boundaryEvent id="SlaBE" attachedToRef="Mark" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1H</bpmn:timeDuration></bpmn:timerEventDefinition>
      <bpmn:outgoing>fSlaE</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:callActivity id="SlaEsc"><bpmn:extensionElements><zeebe:calledElement processId="escalation.sla.breach"/></bpmn:extensionElements>
      <bpmn:incoming>fSlaE</bpmn:incoming><bpmn:outgoing>fSlaE2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="SlaEnd"><bpmn:incoming>fSlaE2</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="fSlaE" sourceRef="SlaBE" targetRef="SlaEsc"/>
    <bpmn:sequenceFlow id="fSlaE2" sourceRef="SlaEsc" targetRef="SlaEnd"/>
    <bpmn:serviceTask id="Notify" name="Notification citoyen"><bpmn:extensionElements><zeebe:taskDefinition type="notification.send"/></bpmn:extensionElements></bpmn:serviceTask>
</bpmn:process>
</bpmn:definitions>
