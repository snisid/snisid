{
  "name": "@snisid/workflow-engine",
  "version": "1.0.0",
  "description": "SNISID National Workflow Engine — Temporal + Zeebe",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "worker:zeebe": "node --enable-source-maps dist/workers/zeebe-worker.js",
    "worker:temporal": "node --enable-source-maps dist/workers/temporal-worker.js",
    "deploy:bpmn": "node dist/governance/deploy-bpmn.js",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@camunda8/sdk": "^8.6.0",
    "@temporalio/client": "^1.10.0",
    "@temporalio/worker": "^1.10.0",
    "@temporalio/workflow": "^1.10.0",
    "@temporalio/activity": "^1.10.0",
    "kafkajs": "^2.2.4",
    "@confluentinc/schemaregistry": "^1.0.0",
    "avsc": "^5.7.7",
    "uuid": "^9.0.1",
    "pino": "^9.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "node-forge": "^1.3.1",
    "axios": "^1.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "eslint": "^9.4.0"
  },
  "engines": { "node": ">=20" }
}
