{
  "uid": "snisid-kafka-mesh",
  "title": "SNISID — Kafka Event Mesh",
  "tags": ["snisid", "kafka", "platform"],
  "timezone": "America/Port-au-Prince",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    { "type": "stat", "title": "Brokers up",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "targets": [{"refId":"A","expr":"count(up{job=\"kafka-broker\"} == 1)"}]
    },
    { "type": "stat", "title": "Under-replicated partitions",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":4,"y":0,"w":4,"h":4},
      "fieldConfig":{"defaults":{"thresholds":{"mode":"absolute","steps":[
        {"color":"green","value":0},{"color":"red","value":1}]}}},
      "targets": [{"refId":"A","expr":"snisid:kafka_under_replicated_partitions:total"}]
    },
    { "type": "stat", "title": "ISR shrinks /s",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":8,"y":0,"w":4,"h":4},
      "targets": [{"refId":"A","expr":"snisid:kafka_isr_shrinks:rate5m"}]
    },
    { "type": "stat", "title": "Lag MAX (msg)",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":12,"y":0,"w":4,"h":4},
      "fieldConfig":{"defaults":{"thresholds":{"mode":"absolute","steps":[
        {"color":"green","value":0},{"color":"orange","value":10000},{"color":"red","value":100000}]}}},
      "targets": [{"refId":"A","expr":"max(snisid:kafka_consumer_lag:max)"}]
    },
    { "type": "stat", "title": "Topics",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":16,"y":0,"w":4,"h":4},
      "targets": [{"refId":"A","expr":"count(count by (topic) (kafka_topic_partition_current_offset))"}]
    },
    { "type": "stat", "title": "Schemas Registry up",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":20,"y":0,"w":4,"h":4},
      "targets": [{"refId":"A","expr":"count(up{job=\"schema-registry\"} == 1)"}]
    },

    { "type": "timeseries", "title": "Messages In/Out par broker",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [
        {"refId":"A","expr":"sum by (instance) (rate(kafka_server_brokertopicmetrics_messagesin_total[5m]))","legendFormat":"in {{instance}}"},
        {"refId":"B","expr":"sum by (instance) (rate(kafka_server_brokertopicmetrics_bytesout_total[5m]))","legendFormat":"out {{instance}}"}
      ]
    },
    { "type": "timeseries", "title": "Top 10 topics par débit",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "targets": [{"refId":"A","expr":"topk(10, sum by (topic) (rate(kafka_topic_partition_current_offset[5m])))","legendFormat":"{{topic}}"}]
    },

    { "type": "timeseries", "title": "Consumer lag par group/topic",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":0,"y":12,"w":24,"h":8},
      "targets": [{"refId":"A","expr":"topk(15, snisid:kafka_consumer_lag:max)","legendFormat":"{{group}} / {{topic}}"}]
    },

    { "type": "table", "title": "Taille topics (bytes)",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":0,"y":20,"w":12,"h":8},
      "fieldConfig":{"defaults":{"unit":"bytes"}},
      "targets": [{"refId":"A","expr":"topk(20, snisid:kafka_topic_size_bytes)","format":"table","instant":true}]
    },
    { "type": "timeseries", "title": "Échecs publication (workflow engine)",
      "datasource": { "type": "prometheus", "uid": "prom-snisid" },
      "gridPos": {"x":12,"y":20,"w":12,"h":8},
      "targets": [{"refId":"A","expr":"sum by (topic) (rate(snisid_kafka_publish_failures_total[5m]))","legendFormat":"{{topic}}"}]
    }
  ]
}
