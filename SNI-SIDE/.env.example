# ============================================================
# SNI-SIDE: Environment Configuration
# Copy to .env and fill in production values
# ============================================================

# Application
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["https://sniside.intranet.pnh.ht"]
# LLM — GraphRAG
LLM_MODEL_PATH=/models/llama-2-7b-chat.gguf
LLM_API_URL=http://localhost:8000/v1
LLM_API_KEY=
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# Server
HOST=0.0.0.0
PORT=8080
WORKERS=4
RELOAD=true

# Security — CHANGE IN PRODUCTION
JWT_SECRET_KEY=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
MTLS_ENABLED=true
SPIRE_SOCKET_PATH=unix:///tmp/spire-agent/public/api.sock

# PostgreSQL — NCID, CODIS, Missing, Vehicle, Firearms, Border, Narcotics, Financial, Cyber, Watchlist, Docs, GEOINT
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sniside
POSTGRES_USER=sniside
POSTGRES_PASSWORD=
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_MIN_CONNECTIONS=10

# CockroachDB — ALPR, Evidence
COCKROACH_HOST=localhost
COCKROACH_PORT=26257
COCKROACH_DB=sniside
COCKROACH_USER=sniside
COCKROACH_PASSWORD=
COCKROACH_MAX_CONNECTIONS=30

# Neo4j — Graph Intelligence
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# Milvus — Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ALIASES_COLLECTION=sniside_face_embeddings
MILVUS_FINGERPRINT_COLLECTION=sniside_fingerprint_templates

# ClickHouse — Analytics
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=sniside
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=sniside-api
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Redis — Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO — Object Store
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_EVIDENCE_BUCKET=sniside-evidence
MINIO_DOCUMENT_BUCKET=sniside-documents

# OpenTelemetry
OTEL_SERVICE_NAME=sniside-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# AI Models
ARCFACE_MODEL_PATH=/models/arcface_v1.pth
FRAUD_GNN_MODEL_PATH=/models/fraud_gnn_v1.pth
DEEPFAKE_MODEL_PATH=/models/deepfake_v1.pth

# Search Engine
SEARCH_DEFAULT_LIMIT=20
SEARCH_MAX_LIMIT=100
SEARCH_TIMEOUT_MS=5000
