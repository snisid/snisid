{
  "target_schema": "snisid_ncid",
  "target_table": "wanted_persons",
  "batch_size": 500,
  "field_mappings": [
    {"source": "niu", "target": "niu", "type": "string", "transformer": "niu_generator", "required": true},
    {"source": "full_name", "target": "full_name", "type": "string", "transformer": "normalize_name", "required": true},
    {"source": "first_name", "target": "first_name", "type": "string", "transformer": "capitalize"},
    {"source": "last_name", "target": "last_name", "type": "string", "transformer": "upper", "required": true},
    {"source": "birth_date", "target": "birth_date", "type": "date", "format": "%d/%m/%Y", "required": true},
    {"source": "birth_place", "target": "birth_place", "type": "string", "transformer": "upper"},
    {"source": "gender", "target": "gender", "type": "enum", "mapping": {"M": "MALE", "F": "FEMALE", "X": "OTHER", "1": "MALE", "2": "FEMALE"}},
    {"source": "nationality", "target": "nationality", "type": "string", "transformer": "upper"},
    {"source": "document_type", "target": "document_type", "type": "string"},
    {"source": "document_number", "target": "document_number", "type": "string"},
    {"source": "address", "target": "address", "type": "text"},
    {"source": "city", "target": "city", "type": "string", "transformer": "upper"},
    {"source": "phone", "target": "phone", "type": "string", "transformer": "phone_normalize"},
    {"source": "email", "target": "email", "type": "string"},
    {"source": "risk_category", "target": "risk_level", "type": "enum",
     "mapping": {"A": "CRITICAL", "B": "HIGH", "C": "MEDIUM", "D": "LOW", "1": "CRITICAL", "2": "HIGH", "3": "MEDIUM", "4": "LOW"}},
    {"source": "status", "target": "status", "type": "enum",
     "mapping": {"ACTIF": "ACTIVE", "INACTIF": "INACTIVE", "ARRETE": "CAPTURED", "DECEDE": "DECEASED", "1": "ACTIVE", "0": "INACTIVE"}},
    {"source": "wanted_since", "target": "wanted_since", "type": "date", "format": "%Y-%m-%d"},
    {"source": "offense_type", "target": "offense_type", "type": "string", "transformer": "upper"},
    {"source": "offense_description", "target": "offense_description", "type": "text"},
    {"source": "warrant_number", "target": "warrant_number", "type": "string"},
    {"source": "issuing_authority", "target": "issuing_authority", "type": "string"},
    {"source": "agency_code", "target": "agency_code", "type": "string", "required": true},
    {"source": "photo_path", "target": "photo_url", "type": "string", "transformer": "file_copy", "copy_to": "sniside-media/photos/"},
    {"source": "fingerprint_hash", "target": "fingerprint_hash", "type": "string"},
    {"source": "notes", "target": "notes", "type": "text"},
    {"source": "last_known_location", "target": "last_known_location", "type": "text"},
    {"source": "created_at", "target": "created_at", "type": "date", "format": "%Y-%m-%d %H:%M:%S"}
  ],
  "validations": [
    {"field": "niu", "rule": "niu_format"},
    {"field": "last_name", "rule": "required"},
    {"field": "birth_date", "rule": "not_future"},
    {"field": "phone", "rule": "phone"},
    {"field": "email", "rule": "email"},
    {"field": "agency_code", "rule": "required", "message": "L'agence est obligatoire"},
    {"field": "full_name", "rule": "min_length", "min": 3}
  ]
}
