# =============================================================================
# SNISID - .dockerignore
# Exclut les fichiers inutiles du contexte Docker pour des builds plus rapides
# et pour éviter de copier des données sensibles dans l'image
# =============================================================================

# Contrôle de version
.git
.gitignore
.gitattributes

# Documentation
*.md
docs/
README*

# Développement local
.env
.env.*
*.local

# Dépendances (reconstruites dans le container)
node_modules/
vendor/

# Builds locaux (on rebuild dans le container)
dist/
build/
frontend/build/
*.exe
*.dll

# Tests
**/*_test.go
**/test/
**/tests/
**/__tests__/
coverage/
*.test.js

# Logs
*.log
logs/

# OS / Éditeurs
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Docker lui-même
Dockerfile*
docker-compose*
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
Jenkinsfile

# Données sensibles (NE JAMAIS inclure dans une image Docker)
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx
configs/local/
configs/secrets/
