{
  "title": "DR Service Dashboard (Golden Signals)",
  "uid": "dr-svc",
  "tags": ["golden-signals", "dr", "platform"],
  "timezone": "browser",
  "panels": [
    {
      "title": "DR Request Rate (QPS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"dr-svc\"}[1m]))",
          "legendFormat": "dr-svc QPS"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "DR Error Rate (HTTP 5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"dr-svc\",status=~\"5..\"}[1m])) / sum(rate(kong_http_requests_total{service=\"dr-svc\"}[1m]))",
          "legendFormat": "Error %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "DR P99 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(kong_latency_bucket{service=\"dr-svc\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Replication Lag (Seconds)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "dr_replication_lag_seconds",
          "legendFormat": "{{site}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
