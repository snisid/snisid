{
  "title": "SNISID Global Overview (Golden Signals)",
  "uid": "snisid-overview",
  "tags": ["golden-signals", "sre", "platform"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Global Request Rate (QPS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Global Error Rate (HTTP 5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{status=~\"5..\"}[1m])) by (service) / sum(rate(kong_http_requests_total[1m])) by (service)",
          "legendFormat": "{{service}} Error %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "P99 Latency (Kong Gateway)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(kong_latency_bucket[5m])) by (le, service))",
          "legendFormat": "{{service}} P99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Kubernetes Saturation (CPU Limit %)",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(node_namespace_pod_container:container_cpu_usage_seconds_total:sum_irate{namespace=\"snisid-core\"}) / sum(kube_pod_container_resource_limits{resource=\"cpu\", namespace=\"snisid-core\"}) * 100",
          "legendFormat": "CPU Saturation %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
