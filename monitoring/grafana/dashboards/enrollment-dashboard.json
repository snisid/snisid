{
  "title": "Enrollment Service Dashboard (Golden Signals)",
  "uid": "enrollment-svc",
  "tags": ["golden-signals", "enrollment", "platform"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Enrollment Request Rate (QPS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"enrollment-svc\"}[1m]))",
          "legendFormat": "enrollment-svc QPS"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Enrollment Error Rate (HTTP 5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"enrollment-svc\",status=~\"5..\"}[1m])) / sum(rate(kong_http_requests_total{service=\"enrollment-svc\"}[1m]))",
          "legendFormat": "Error %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Enrollment P99 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(kong_latency_bucket{service=\"enrollment-svc\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Enrollment Processing Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(enrollment_requests_total[1m])",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
