{
  "title": "Card Service Dashboard (Golden Signals)",
  "uid": "card-svc",
  "tags": ["golden-signals", "card", "platform"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Card Request Rate (QPS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"card-svc\"}[1m]))",
          "legendFormat": "card-svc QPS"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Card Error Rate (HTTP 5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"card-svc\",status=~\"5..\"}[1m])) / sum(rate(kong_http_requests_total{service=\"card-svc\"}[1m]))",
          "legendFormat": "Error %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Card P99 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(kong_latency_bucket{service=\"card-svc\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Card Production Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(card_production_total[1m])",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
