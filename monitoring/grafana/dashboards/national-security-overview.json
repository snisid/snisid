{
  "title": "National Security — Service Overview (Golden Signals)",
  "uid": "ns-overview",
  "tags": ["ns", "golden-signals", "sre", "national-security"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Service Health (Up/Down)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(up{namespace=\"ns-core\", service=~\"ns-(vc|pki|sd-jwt|did|vp|status-list|didcomm|credential-flow|siopv2|wallet|chapi|credential-manifest|revocation)\"} == 1)",
          "legendFormat": "Services Up"
        }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "title": "Request Rate (QPS) — All NS Services",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ns_http_requests_total{service=~\"ns-(vc|pki|sd-jwt|did|vp|status-list|didcomm|credential-flow|siopv2|wallet|chapi|credential-manifest|revocation)\"}[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "title": "Error Rate (5xx %) — All NS Services",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ns_http_requests_total{service=~\"ns-(vc|pki|sd-jwt|did|vp|status-list|didcomm|credential-flow|siopv2|wallet|chapi|credential-manifest|revocation)\", status=~\"5..\"}[1m])) by (service) / sum(rate(ns_http_requests_total{service=~\"ns-(vc|pki|sd-jwt|did|vp|status-list|didcomm|credential-flow|siopv2|wallet|chapi|credential-manifest|revocation)\"}[1m])) by (service) * 100",
          "legendFormat": "{{service}} Error %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },
    {
      "title": "P95 Latency — All NS Services",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ns_request_duration_seconds_bucket{service=~\"ns-(vc|pki|sd-jwt|did|vp|status-list|didcomm|credential-flow|siopv2|wallet|chapi|credential-manifest|revocation\"}[5m])) by (le, service))",
          "legendFormat": "{{service}} P95"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 }
    },
    {
      "title": "Kafka Producer Message Rate — All NS Services",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ns_kafka_producer_messages_total{service=~\"ns-(vc|pki|sd-jwt|did|vp|status-list|didcomm|credential-flow|siopv2|wallet|chapi|credential-manifest|revocation)\"}[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 }
    }
  ]
}
