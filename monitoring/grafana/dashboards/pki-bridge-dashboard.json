{
  "title": "PKI Bridge Dashboard (Golden Signals)",
  "uid": "pki-bridge-svc",
  "tags": ["golden-signals", "pki-bridge", "platform"],
  "timezone": "browser",
  "panels": [
    {
      "title": "PKI Bridge Request Rate (QPS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"pki-bridge-svc\"}[1m]))",
          "legendFormat": "pki-bridge-svc QPS"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "PKI Bridge Error Rate (HTTP 5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=\"pki-bridge-svc\",status=~\"5..\"}[1m])) / sum(rate(kong_http_requests_total{service=\"pki-bridge-svc\"}[1m]))",
          "legendFormat": "Error %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "PKI Bridge P99 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(kong_latency_bucket{service=\"pki-bridge-svc\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Cross-Cert Validation Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pki_bridge_validations_total[1m])",
          "legendFormat": "{{result}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
