{
  "title": "Biometrics AI Performance",
  "uid": "snisid-biometrics",
  "tags": ["ai", "biometrics", "performance"],
  "timezone": "browser",
  "panels": [
    {
      "title": "1:N Matching Execution Time (Faiss)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(biometric_matching_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 Matching Latency (seconds)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Liveness Detection (PAD) Rejection Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(biometric_liveness_rejections_total[1h])) / sum(rate(biometric_liveness_requests_total[1h])) * 100",
          "legendFormat": "Spoof Rejection %"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "NIST Quality Score Distribution",
      "type": "heatmap",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(biometric_quality_score_bucket[1h])) by (le)",
          "format": "heatmap"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    }
  ]
}
